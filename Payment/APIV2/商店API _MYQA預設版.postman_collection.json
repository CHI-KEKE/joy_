          "let body = {};",
          "if(requestBody.mode == \"formdata\"){",
          "    const formdata = requestBody.formdata.members;",
          "    body = convertFormDataToJson(formdata)",
          "}else{",
          "    body = JSON.parse(requestBody.raw);",
          "}",
          "",
          "const content = \"ts=\"+ timestamp+\"&data=\" + JSON.stringify(body).toLowerCase() + \"&sk=\" + saltKey;",
          "console.log(\"apiKey: \" , apiKey);",
