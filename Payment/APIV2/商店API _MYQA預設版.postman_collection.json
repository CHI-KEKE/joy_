        "exec": [
          "// 取得Timestamp",
          "let timestamp = getTimestamp();",
          "",
          "// 取得Signature",
          "const signatureApiUrl = pm.collectionVariables.get(\"API_URL\") + \"/scm/v1/Sample/GetEncryptData\";",
          "const apiKey = pm.collectionVariables.get(\"API_Key\");",
          "const saltKey = pm.collectionVariables.get(\"SaltKey\");",
