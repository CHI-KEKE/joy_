          "});",
          "",
          "",
          "function getTimestamp(){",
          "    const gtm = new Date(Date.UTC(1970, 0, 1));",
          "",
          "    const utc = new Date();",
          "    const utcOffsetInHours = 8; // UTC+8",
          "    const localTime = new Date(utc.getTime() + (utcOffsetInHours * 60 * 60 * 1000));",
          "",
          "    const timestamp = Math.floor((localTime - gtm) / 1000);",
          "    //const timestamp = \"1722002520\";",
          "    pm.collectionVariables.set(\"Timestamp\", timestamp);",
          "    return timestamp;",
          "}",
          "",
          "function convertFormDataToJson(obj){",
          "    const formdata = requestBody.formdata.members;",
          "    var result = {};",
          "    formdata.forEach(item => {",
          "        result[item.key] = item.value;",
          "    });",
          "    return convertStringNumbers(result)",
          "}",
          "",
          "function convertStringNumbers(obj) {",
          "    for (const key in obj) {",
          "        if (obj.hasOwnProperty(key)) {",
          "            if (typeof obj[key] === 'string' && !isNaN(obj[key])) {",
          "                obj[key] = Number(obj[key]);",
          "            } else if (typeof obj[key] === 'object' && obj[key] !== null) {",
          "                convertStringNumbers(obj[key]);",
          "            }",
          "        }",
          "    }",
          "    return obj;",
          "}"
        ]
