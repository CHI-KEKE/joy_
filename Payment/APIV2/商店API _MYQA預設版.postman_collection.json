          "console.log(\"body: \", body);",
          "console.log(\"saltKey: \", saltKey);",
          "console.log(\"content: \", content);",
          "pm.sendRequest({",
          "    url: signatureApiUrl,",
          "    method: 'POST',",
          "    header: {",
          "        'Content-Type': 'multipart/form-data'",
