						"type": "text"
					},
					{
						"key": "x-pos-content-employee-code",
						"value": "{{employee_code}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{{request_body}}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{api_host}}/pos/v1/GetMemberInfo?t={{token}}&ts={{timestamp}}&s={{signature}}",
					"host": [
						"{{api_host}}"
					],
					"path": [
						"pos",
