	"item": [
		{
			"name": "查詢會員",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const phone = pm.environment.get(\"phone\");\r",
							"const outermembercode = pm.environment.get(\"outermembercode\");\r",
							"const membercode = pm.environment.get(\"member_code\");\r",
							"const shopId = parseInt(pm.environment.get(\"shop_id\"));\r",
							"// 修改request-body\r",
							"var body = {\r",
							"    \"OuterMemberCode\": outermembercode,\r",
							"    \"MemberCode\": membercode,\r",
							"    \"CellPhone\": phone\r",
							"}\r",
							"\r",
							"var body_data = JSON.stringify(body)\r",
							"\r",
							"// 取得Timestamp\r",
							"pm.sendRequest({\r",
							"    url: pm.environment.get(\"scm_api\") + '/scm/v1/Utils/GetCurrentTime',\r",
							"    method: 'POST',\r",
							"    header: {\r",
							"        'content-type': 'application/json',\r",
							"    }\r",
							"}, function (err, response) {\r",
							"    const timestamp = response.json()\r",
							"    // console.log(\"取得Timestamp : \" + timestamp)\r",
							"    pm.environment.set(\"timestamp\", timestamp);\r",
							"\r",
							"    var body =  body_data.toLowerCase();\r",
							"    // 取得Signature\r",
							"    var content = \"ts=\" + pm.environment.get(\"timestamp\") + \"&data=\" + body + \"&sk=\" + pm.environment.get(\"salt_key\")\r",
							"\r",
							"     console.log(\"取得Signature : \" + content)\r",
							"    pm.sendRequest({\r",
							"        url: pm.environment.get(\"scm_api\") + '/scm/v1/Sample/GetEncryptData',\r",
							"        method: 'POST',\r",
							"        header: {\r",
							"            'Content-Type': 'multipart/form-data',\r",
							"            },\r",
							"        body: {\r",
							"            mode: 'formdata',\r",
							"            formdata: [\r",
							"            {\r",
							"                key: \"key\", \r",
							"                value: pm.environment.get(\"api_key\"), \r",
							"                disabled: false, \r",
							"                description: {content:\"\", type:\"text/plain\"}\r",
							"                },\r",
							"            {\r",
							"                key: \"content\", \r",
							"                value: content, \r",
							"                disabled: false, \r",
							"                description: {content:\"\", type:\"text/plain\"}\r",
							"                }\r",
							"            ]\r",
							"        }\r",
							"    },  function(err, response) {\r",
							"        const signature = response.json().Data\r",
							"        pm.environment.set(\"signature\", signature);\r",
							"    });\r",
							"});\r",
							"\r",
							"request_body = body_data\r",
							"// console.log(\"4. 取得request_body:\" + request_body)\r",
							"pm.environment.set(\"request_body\", request_body);\r",
							"\r",
							"function interpolate (value) {\r",
							"    const {Property} = require('postman-collection');\r",
							"    return Property.replaceSubstitutions(value, pm.variables.toObject());\r",
							"}\r",
							""
						],
						"type": "text/javascript"
					}
				}
			],
			"protocolProfileBehavior": {
				"tlsPreferServerCiphers": false,
				"tlsDisabledProtocols": []
			},
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "NY-SHOP-ID",
						"value": "{{shop_Id}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json;charset=utf-8 ",
